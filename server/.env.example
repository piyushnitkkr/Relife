# ============================================================
# ReLife AI — AWS Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# AWS Credentials (use IAM role on EC2, or set these for local dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# MongoDB Atlas (Free M0 Cluster)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/relife_ai?retryWrites=true&w=majority

# DynamoDB Table
DYNAMO_TABLE_NAME=relife-user-credits

# S3 Bucket (product images)
S3_BUCKET=relife-ai-assets

# AWS Cognito (Auth)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1

# SNS Topic ARN (P2P notifications)
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:relife-notifications

# Frontend URL (for CORS)
FRONTEND_URL=https://main.xxxxxxxx.amplifyapp.com

# App Settings
APP_ENV=production
DEBUG=false
PORT=8000
