# ============================================================
# ReLife AI — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# App Mode
APP_ENV=production
DEBUG=false
PORT=8000

# Frontend URL (your Vercel URL)
FRONTEND_URL=https://relife-tan.vercel.app/

# ---- AWS Credentials ----
# Option 1: Use IAM Role on EC2 (recommended - no keys needed)
# Option 2: Set these for local dev
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- MongoDB Atlas (Free M0 Cluster) ----
# Get from: https://cloud.mongodb.com → Connect → Drivers → Python
MONGO_URI=mongodb+srv://piyushmittal78331_db_user:ArDuDHT4enslkq5M@relife.0qdfbqf.mongodb.net/

# ---- AWS DynamoDB (Free 25 GB) ----
DYNAMO_TABLE_NAME=relife-user-credits

# ---- AWS S3 (Free 5 GB) ----
S3_BUCKET=relife-ai-assets

# ---- AWS Cognito (Free 50K MAU) ----
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# ---- AWS SNS (Free 1M notifications) ----
SNS_TOPIC_ARN=



