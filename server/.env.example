# ============================================================
# ReLife AI — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

APP_ENV=production
DEBUG=false
PORT=8000

# Frontend URL (your Vercel URL)
FRONTEND_URL=https://your-app.vercel.app

# MongoDB Atlas (Free M0 Cluster)
MONGO_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/relife_ai?retryWrites=true&w=majority

# Gemini AI API Key (from aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSy...your-key

# AWS Region (for any future AWS services)
AWS_REGION=us-east-1
